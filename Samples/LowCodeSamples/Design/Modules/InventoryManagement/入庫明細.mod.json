        "Parameters": [
          {
            "IsParameter": true,
            "Name": "product_id",
            "DbType": "INTEGER",
            "DbParameterDirection": "Input"
          },
          {
            "IsParameter": true,
            "Name": "quantity",
            "DbType": "INTEGER",
            "DbParameterDirection": "Input"
          }
        ],
        "SqlText": "INSERT INTO inventory(product_id, warehouse_id, current_stock, version, created_at, updated_at)\nSELECT\n  @product_id::integer,\n  r.warehouse_id,\n  @quantity::integer,\n  0,\n  CURRENT_TIMESTAMP,\n  CURRENT_TIMESTAMP\nFROM receiving r\nJOIN receiving_detail rd ON rd.receiving_id = r.id\nWHERE rd.id = currval(pg_get_serial_sequence('receiving_detail', 'id'))\nON CONFLICT(product_id, warehouse_id)\nDO UPDATE SET\n  current_stock = inventory.current_stock + excluded.current_stock,\n  version = inventory.version + 1,\n  updated_at = excluded.updated_at;\n"
      },
      "Name": "在庫加算",
      "IgnoreModification": false,
