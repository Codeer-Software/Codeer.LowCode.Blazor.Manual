{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DataSources": [
    {
      "Name": "SampleSQLite",
      "DataSourceType": "SQLite"
    },
    {
      "Name": "PatternsSQLite",
      "DataSourceType": "SQLite"
    }
  ],
  "PasswordCheckUserTableInfo": {
    "TableName": "app_users",
    "IdColumn": "id",
    "UserNameColumn": "user_name",
    "HashColumn": "hash",
    "SaltColumn": "salt"
  },
  "TemporaryFileTableInfo": [
    {
      "DataSourceName": "SampleSQLite",
      "Table": "temporary_files",
      "GuidColumn": "guid",
      "CreatedDateTimeColumn": "created_date_time"
    },
    {
      "DataSourceName": "PatternsSQLite",
      "Table": "temporary_files",
      "GuidColumn": "guid",
      "CreatedDateTimeColumn": "created_date_time"
    }
  ]
}
