<designer:DesignerApp x:Class="LowCodeApp.WPF.LicenseRegister.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:designer="clr-namespace:Codeer.LowCode.Blazor.Designer;assembly=Codeer.LowCode.Blazor.Designer"
             xmlns:system="clr-namespace:System;assembly=System.Runtime">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Codeer.LowCode.Blazor.Designer;component/AppResources.xaml" />
      </ResourceDictionary.MergedDictionaries>

      <system:String x:Key="LicenseManager.Register.Title">LowCodeApp.WPF: Register</system:String>
      <system:String x:Key="LicenseManager.Unregister.Title">LowCodeApp.WPF: Unregister</system:String>
    </ResourceDictionary>
  </Application.Resources>
</designer:DesignerApp>
