    },
    {
      "Text": "CanCreate/CanUpdate/CanDelete は ListField と同じ。デフォルト true (詳細画面では編集UI出す)。",
      "Icon": "",
      "Style": "Default",
      "RelativeField": "",
      "OnClick": "",
